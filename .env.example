# =============================================================================
# .env.example — Template for Tender Monitoring System Credentials
#
# Copy this to .env and fill in your actual credentials.
# DO NOT commit .env to version control (it is in .gitignore).
# =============================================================================

# ── MySQL Database ─────────────────────────────────────────────────────────
# Canonical local setup: native MySQL on 127.0.0.1:3306
# If you use docker-compose's MySQL instead, set DB_PORT=3307 in your local .env.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_MYSQL_PASSWORD
DB_NAME=tender_monitor

# ── Telegram Notifications ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Email Notifications ────────────────────────────────────────────────────
# Tender alerts + daily digest both use these env vars.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=alerts@example.com
SMTP_FROM_NAME=TenderRadar
NOTIFY_EMAIL_TO=your@email.com
AUTO_DAILY_DIGEST=1
DAILY_DIGEST_DRY_RUN=1
DAILY_DIGEST_ATTACH_PACKAGES=1
DAILY_DIGEST_MAX_PACKAGES=5

# ── Twilio WhatsApp ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=YOUR_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_NUMBERS=+XXXXXXXXXX

# ── SAM.gov API (free key — https://open.gsa.gov/api/get-started/) ─────────
SAM_API_KEY=YOUR_SAM_API_KEY

# ── OpenAI (intelligence layer — GPT-4o or GPT-5.4) ──────────────────────
OPENAI_API_KEY=sk-YOUR_API_KEY_HERE

# =============================================================================
# PORTAL CREDENTIALS
# =============================================================================

# World Bank eConsultant
WB_USER=your_email@example.com
WB_PASS=your_password

# UNDP Procurement Notices
UNDP_USER=your_email@example.com
UNDP_PASS=your_password

# UNGM (UN Global Marketplace)
UNGM_USER=your_email@example.com
UNGM_PASS=your_password

# GeM (Government e-Marketplace)
GEM_USER=your_email@example.com
GEM_PASS=your_password

# SAM.gov — LLC Entity
SAM_LLC_USER=your_email@example.com
SAM_LLC_PASS=your_password
SAM_LLC_ENTITY=YOUR_ENTITY_ID

# SAM.gov — India Entity
SAM_INDIA_USER=your_email@example.com
SAM_INDIA_PASS=your_password
SAM_INDIA_ENTITY=YOUR_ENTITY_ID

# USAID
USAID_USER=your_email@example.com
USAID_PASS=your_password

# DTVP (Deutsches Vergabeportal)
DTVP_USER=your_email@example.com
DTVP_PASS=your_password

# AfDB (African Development Bank)
AFDB_USER=your_email@example.com
AFDB_PASS=your_password

# CG eProcurement
CG_USER=your_email@example.com
CG_PASS=your_password

# Karnataka eProcurement
KARNATAKA_USER=your_user_id
KARNATAKA_PASS=your_password

# Tanzania TANEPS
TANEPS_USER=your_username
TANEPS_PASS=your_password

# UN Dev Business
DEVBUSINESS_USER=your_email@example.com
DEVBUSINESS_PASS=your_password

# UNIDO Procurement
UNIDO_USER=your_user_id
UNIDO_PASS=your_password

# IOM (Oracle Cloud)
IOM_USER=your_email@example.com
IOM_PASS=your_password
